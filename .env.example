# Core API URL
VITE_API_BASE_URL=http://localhost:8080/api
VITE_API_TIMEOUT_MS=15000

# Auth endpoints (override only if backend uses different paths)
VITE_AUTH_LOGIN_ENDPOINT=/auth/login
VITE_AUTH_REGISTER_ENDPOINT=/auth/register
VITE_AUTH_LOGOUT_ENDPOINT=/auth/logout
VITE_AUTH_ME_ENDPOINT=/auth/me

# Development helper
VITE_USE_AUTH_MOCK=false

# Show/hide quick login buttons at bottom of Login screen
VITE_SHOW_DEV_LOGIN_BUTTONS=false
