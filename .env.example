Failed to load resource: the server responded with a status of 403 ()# Core API URL
VITE_API_BASE_URL=https://ezequiel-gateway-etcrh9dxg9dwhng4.canadacentral-01.azurewebsites.net
VITE_API_TIMEOUT_MS=15000

# Dedicated websocket channel for auctions realtime updates.
# Development default in code: ws://localhost:8080/ws
# Example production value: wss://<your-backend-host>/ws
VITE_AUCTION_WS_URL= ws//localhost8081/ws

# Auth endpoints (override only if backend uses different paths)
VITE_AUTH_LOGIN_ENDPOINT=/api/auth/login
VITE_AUTH_REGISTER_ENDPOINT=/api/auth/register
VITE_AUTH_LOGOUT_ENDPOINT=/api/auth/logout
VITE_AUTH_ME_ENDPOINT=/api/auth/me

# Development helper
VITE_USE_AUTH_MOCK=false

# Show/hide quick login buttons at bottom of Login screen
VITE_SHOW_DEV_LOGIN_BUTTONS=false
