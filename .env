# MediGo - Local Environment Configuration

# URL base del backend REST (gateway o backend directo en dev)
VITE_API_BASE_URL=http://localhost:8080

# URL WebSocket para subastas y ubicacion (STOMP sobre WS)
VITE_WS_URL=wss://wsmedigo-facaf0hcfxakeph8.brazilsouth-01.azurewebsites.net/ws

# Timeout global de requests (ms)
VITE_API_TIMEOUT_MS=15000

# Endpoints de autenticacion
VITE_AUTH_LOGIN_ENDPOINT=/api/auth/login
VITE_AUTH_REGISTER_ENDPOINT=/api/auth/register
VITE_AUTH_LOGOUT_ENDPOINT=/api/auth/logout
VITE_AUTH_ME_ENDPOINT=/api/auth/me

# Config de desarrollo
VITE_USE_AUTH_MOCK=false
VITE_SHOW_DEV_LOGIN_BUTTONS=true
VITE_ENABLE_TRACE_ID_HEADER=false
