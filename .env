# Variables de entorno — MediGo Frontend

# URL base del backend REST (gateway)
#VITE_API_BASE_URL=https://ezequiel-gateway-etcrh9dxg9dwhng4.canadacentral-01.azurewebsites.net
VITE_API_BASE_URL=

# URL WebSocket para ubicación en tiempo real (STOMP sobre WS)
# En producción apunta al backend directamente (el gateway de Azure no hace proxy WS)
#VITE_WS_URL=wss://medi-go-app.azurewebsites.net/ws
VITE_WS_URL=
# Timeout global de requests (ms)
VITE_API_TIMEOUT_MS=15000

# Endpoints de autenticacion (solo cambiar si backend usa rutas diferentes)
VITE_AUTH_LOGIN_ENDPOINT=/api/auth/login
VITE_AUTH_REGISTER_ENDPOINT=/api/auth/register
VITE_AUTH_LOGOUT_ENDPOINT=/api/auth/logout
VITE_AUTH_ME_ENDPOINT=/api/auth/me

# Activar/desactivar mock login de desarrollo
VITE_USE_AUTH_MOCK=false

# Mostrar/ocultar botones de acceso rapido de desarrollo en Login
VITE_SHOW_DEV_LOGIN_BUTTONS=true

# Header opcional para trazabilidad (activar solo si backend permite X-Trace-Id en CORS)
VITE_ENABLE_TRACE_ID_HEADER=false
